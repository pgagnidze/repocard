    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2"
  },
  "devDependencies": {
    "tsdown": "^0.12.5",
    "typescript": "^5.8.3"
  }
}
